{
  "name": "convex-saas",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "bun@1.3.9",
  "type": "module",
  "scripts": {
    "prepare": "lefthook install",
    "start": "bun run dev",
    "dev": "turbo run dev",
    "dev:frontend": "turbo run dev --filter=@repo/web",
    "dev:backend": "turbo run dev --filter=@repo/backend",
    "predev": "turbo run setup --filter=@repo/backend",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "preview": "turbo run preview --filter=@repo/web"
  },
  "dependencies": {
    "@auth/core": "^0.34.1",
    "@convex-dev/auth": "^0.0.43",
    "@convex-dev/react-query": "^0.0.0-alpha.3",
    "@epic-web/client-hints": "^1.3.2",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@react-email/components": "0.0.22",
    "@tanstack/react-form": "0.26.4",
    "@tanstack/react-query": "^5.51.15",
    "@tanstack/react-router": "^1.45.11",
    "@tanstack/zod-form-adapter": "^0.26.4",
    "@xixixao/uploadstuff": "^0.0.5",
    "class-variance-authority": "^0.7.0",
    "convex": "^1.13.2",
    "convex-helpers": "^0.1.50",
    "cookie": "^0.6.0",
    "i18next": "^23.12.2",
    "i18next-browser-languagedetector": "^8.0.0",
    "i18next-http-backend": "^2.5.2",
    "lucide-react": "^0.416.0",
    "oslo": "^1.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^15.0.0",
    "resend": "^3.2.0",
    "stripe": "^16.6.0",
    "tailwind-merge": "^2.4.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@tanstack/router-devtools": "^1.45.11",
    "@tanstack/router-plugin": "^1.45.8",
    "@types/cookie": "^0.6.0",
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "lefthook": "^2.1.2",
    "oxlint": "^1.51.0",
    "postcss": "^8.4.40",
    "prettier": "3.3.3",
    "tailwindcss": "^3.4.7",
    "turbo": "^2.8.13",
    "typescript": "^5.5.4",
    "vite": "^5.3.4"
  }
}
