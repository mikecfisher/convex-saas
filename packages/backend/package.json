{
  "name": "@repo/backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bunx convex dev",
    "setup": "bunx convex dev --run init --until-success",
    "build": "bun run typecheck",
    "lint": "oxlint --config .oxlintrc.json convex --deny-warnings",
    "typecheck": "tsc -p convex/tsconfig.json",
    "deploy": "bunx convex deploy --cmd 'bun run --cwd ../.. build'"
  }
}
